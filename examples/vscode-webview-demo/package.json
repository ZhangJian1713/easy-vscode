{
  "name": "vscode-webview-demo",
  "displayName": "Webview Demo",
  "description": "Minimal demo for testing easy-vscode runtime and webview messaging",
  "version": "0.0.1",
  "publisher": "local-dev",
  "private": true,
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:webview-demo.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "webview-demo.open",
        "title": "Open Webview Demo"
      }
    ]
  },
  "scripts": {
    "prepare:easy-vscode": "yarn --cwd ../../packages/core node ../../node_modules/typescript/bin/tsc --build tsconfig.json && rm -rf ./node_modules/@easy_vscode/core/lib && cp -R ../../packages/core/lib ./node_modules/@easy_vscode/core/lib && rm -rf ./node_modules/@easy_vscode/webview && cp -R ../../packages/webview ./node_modules/@easy_vscode/webview && rm -rf ./node_modules/@easy_vscode/webview/node_modules",
    "vendor:template": "node scripts/vendor-minimal-react-template.cjs",
    "compile": "webpack --config webpack.extension.js",
    "watch": "webpack --config webpack.extension.js --watch",
    "ui-dev": "webpack serve --config scaffold/webview.webpack.js --mode development",
    "ui-build": "webpack --config scaffold/webview.webpack.js --mode production",
    "package": "yarn ui-build && yarn compile",
    "check-type": "tsc --noEmit"
  },
  "dependencies": {
    "@easy_vscode/core": "^1.7.2",
    "@easy_vscode/webview": "^1.6.9",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.14.8",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@babel/preset-env": "^7.14.8",
    "@babel/preset-react": "^7.14.5",
    "@babel/preset-typescript": "^7.14.5",
    "@types/node": "14.x",
    "@types/react": "^17.0.62",
    "@types/react-dom": "^17.0.20",
    "@types/vscode": "^1.60.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-styled-components": "^2.1.4",
    "clean-webpack-plugin": "^4.0.0-alpha.0",
    "css-loader": "^6.2.0",
    "fork-ts-checker-webpack-plugin": "4.1.6",
    "html-webpack-plugin": "^5.3.2",
    "less": "^4.1.1",
    "less-loader": "^10.0.1",
    "mini-css-extract-plugin": "^2.1.0",
    "react-hot-loader": "^4.13.1",
    "style-loader": "^3.2.1",
    "terser-webpack-plugin": "^5.1.4",
    "ts-loader": "^9.2.3",
    "typescript": "^4.3.5",
    "webpack": "^5.45.1",
    "webpack-cli": "^4.7.2",
    "webpack-dev-server": "^3.11.2"
  }
}
